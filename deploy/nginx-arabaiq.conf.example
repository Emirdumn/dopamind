# ═══════════════════════════════════════════════════════════════════════
#  ArabaIQ — host nginx reverse-proxy site config
#
#  Purpose:
#    Lives OUTSIDE the container stack on the VPS host. Sits in front of
#    the docker-compose.prod.yml services that bind to loopback ports
#    127.0.0.1:3001 (frontend) and 127.0.0.1:8101 (API).
#
#  Install:
#    sudo cp deploy/nginx-arabaiq.conf.example /etc/nginx/sites-available/arabaiq
#    sudo ln -s /etc/nginx/sites-available/arabaiq /etc/nginx/sites-enabled/
#    sudo nginx -t && sudo systemctl reload nginx
#
#  Cloudflare note:
#    Cloudflare is in front, doing SSL termination (Flexible mode). The
#    browser talks HTTPS to Cloudflare; Cloudflare talks plain HTTP to
#    this nginx on port 80. Later we can upgrade to "Full (strict)" by
#    installing a Cloudflare Origin Certificate and uncommenting the
#    :443 server block below.
# ═══════════════════════════════════════════════════════════════════════

# ── Upstream pools — container ports bound to loopback ─────────────────
upstream arabaiq_frontend {
    server 127.0.0.1:3001;
    keepalive 16;
}

upstream arabaiq_api {
    server 127.0.0.1:8101;
    keepalive 16;
}

# ── Cloudflare real client IP recovery ─────────────────────────────────
# Makes `$remote_addr` return the browser IP instead of the Cloudflare
# edge. Add the current Cloudflare IP list via:
#     curl https://www.cloudflare.com/ips-v4 | awk '{print "set_real_ip_from " $0 ";"}'
# and save the output to /etc/nginx/snippets/cloudflare-ips.conf
include /etc/nginx/snippets/cloudflare-ips.conf;
real_ip_header CF-Connecting-IP;

# ── HTTP → (same) HTTP, served to Cloudflare edge ──────────────────────
# When you switch Cloudflare to "Full (strict)", move the bodies below
# into a `listen 443 ssl http2;` block and keep this :80 block only as
# a redirect.
server {
    listen 80;
    listen [::]:80;
    server_name arabaiq.com www.arabaiq.com;

    # Redirect www → apex (optional but recommended)
    if ($host = www.arabaiq.com) {
        return 301 $scheme://arabaiq.com$request_uri;
    }

    # Upload cap — tune if you ever accept user car photos, etc.
    client_max_body_size 20M;

    # ── API reverse proxy ─────────────────────────────────────────────
    location /api/ {
        proxy_pass http://arabaiq_api;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header Connection        "";
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    # ── Health endpoint (FastAPI) ─────────────────────────────────────
    location = /health {
        proxy_pass http://arabaiq_api;
        access_log off;
    }

    # ── Next.js static assets — long-term cache, immutable filenames ──
    location /_next/static/ {
        proxy_pass http://arabaiq_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # ── Everything else → Next.js SSR ─────────────────────────────────
    location / {
        proxy_pass http://arabaiq_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection        "";
        proxy_read_timeout 60s;
    }

    # Gzip — Cloudflare already compresses on the edge, but enabling this
    # keeps non-CF direct-origin requests efficient too.
    gzip on;
    gzip_vary on;
    gzip_types text/plain application/json application/javascript
               text/css text/xml application/xml application/xml+rss
               image/svg+xml;
}
