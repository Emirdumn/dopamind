# ArabaIQ API — PostgreSQL (docker-compose: araba-iq-db @ 5433)
# psycopg3: postgresql:// veya postgresql+psycopg:// (kod otomatik +psycopg ekler)
DATABASE_URL=postgresql://araba_iq:changeme@localhost:5433/araba_iq

# Opsiyonel (Next.js frontend için tarayıcı CORS)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Opsiyonel
API_V1_PREFIX=/api/v1
PROJECT_NAME=ArabaIQ
SEGMENTO_TAGLINE=Segmento — segment ve filtre motoru
