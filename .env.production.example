# ═══════════════════════════════════════════════════════════════════════
#  ArabaIQ — production env template
#
#  On the VPS, copy this to `.env.production` in the same directory as
#  docker-compose.prod.yml and fill in the real values. NEVER commit the
#  real file (`.gitignore` already blocks it).
# ═══════════════════════════════════════════════════════════════════════

# ── Postgres ───────────────────────────────────────────────────────────
# Pick a strong random password. Change ONLY before first `docker compose up`
# — changing it later requires resetting the araba_iq_db_prod volume.
#   openssl rand -base64 32
ARABA_IQ_DB_PASSWORD=change-me-to-a-long-random-string

# ── OtoApi (vehicle valuation) ─────────────────────────────────────────
# Server-side only — Next.js reads this at request time (not build time)
# and never exposes it to the browser.
OTOAPI_KEY=your-otoapi-key-here
