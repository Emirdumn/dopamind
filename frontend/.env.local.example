# ArabaIQ FastAPI (recommendations + compare)
NEXT_PUBLIC_ARABAIQ_API_URL=http://localhost:8100/api/v1

# ─── OtoApi (vehicle valuation) ──────────────────────────────────
# Server-side only — NEVER add NEXT_PUBLIC_ prefix to this key.
OTOAPI_KEY=your_otoapi_key_here

# Optional: override OtoApi base URL (default: https://otoapi.com/api)
# OTOAPI_BASE_URL=https://otoapi.com/api
