<style>
  .main-collection-section {
    background: #E0E7D7;
    padding: 0 0 80px;
  }
  .mc-hero {
    background: linear-gradient(135deg, #5a7a52 0%, #B7C396 100%);
    padding: 60px 24px;
    text-align: center;
    margin-bottom: 48px;
  }
  .mc-hero-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 8px;
  }
  .mc-hero-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .mc-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .mc-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(45, 58, 42, 0.1);
  }
  .mc-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .mc-filter-btn {
    padding: 8px 18px;
    border: 1.5px solid rgba(45, 58, 42, 0.2);
    border-radius: 20px;
    background: #fff;
    color: #2d3a2a;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .mc-filter-btn:hover,
  .mc-filter-btn.active {
    background: #5a7a52;
    color: #fff;
    border-color: #5a7a52;
  }
  .mc-toolbar-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .mc-sort-select {
    padding: 10px 16px;
    border: 1.5px solid rgba(45, 58, 42, 0.2);
    border-radius: 10px;
    background: #fff;
    color: #2d3a2a;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .mc-count {
    font-size: 0.9rem;
    color: #2d3a2a;
    opacity: 0.6;
  }

  /* Product Grid */
  .mc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  @media (max-width: 1024px) {
    .mc-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .mc-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .mc-toolbar { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .mc-grid { grid-template-columns: 1fr; max-width: 360px; margin-left: auto; margin-right: auto; }
  }
  .mc-card {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(45, 58, 42, 0.06);
    transition: transform 0.3s, box-shadow 0.3s;
    text-decoration: none;
    color: #2d3a2a;
    display: flex;
    flex-direction: column;
  }
  .mc-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(45, 58, 42, 0.12);
  }
  .mc-card-img-wrap {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f0f4eb;
  }
  .mc-card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .mc-card:hover .mc-card-img-wrap img {
    transform: scale(1.05);
  }
  .mc-card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #5a7a52;
    color: #fff;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
  }
  .mc-card-body {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .mc-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .mc-card-price {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .mc-card-price-current {
    font-size: 1.05rem;
    font-weight: 700;
    color: #5a7a52;
  }
  .mc-card-price-compare {
    font-size: 0.85rem;
    color: #2d3a2a;
    opacity: 0.5;
    text-decoration: line-through;
  }

  /* Pagination */
  .mc-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 48px;
    grid-column: 1 / -1;
  }
  .mc-pagination a,
  .mc-pagination span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    border-radius: 10px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    color: #2d3a2a;
    border: 1.5px solid rgba(45, 58, 42, 0.15);
    transition: all 0.2s;
  }
  .mc-pagination a:hover {
    background: #B7C396;
    border-color: #B7C396;
  }
  .mc-pagination .mc-page-current {
    background: #5a7a52;
    color: #fff;
    border-color: #5a7a52;
  }
</style>

{%- assign products_per_page = section.settings.products_per_page -%}

<section class="main-collection-section" data-section-id="{{ section.id }}">
  <!-- Collection Hero -->
  <div class="mc-hero">
    <h1 class="mc-hero-title">{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <p class="mc-hero-desc">{{ collection.description | strip_html }}</p>
    {% endif %}
  </div>

  <div class="mc-inner">
    <!-- Toolbar -->
    <div class="mc-toolbar">
      <div class="mc-filters">
        <a href="{{ collection.url }}" class="mc-filter-btn {% unless current_tags %}active{% endunless %}">All</a>
        {% for tag in collection.all_tags %}
          {% if current_tags contains tag %}
            <a href="{{ collection.url }}" class="mc-filter-btn active">{{ tag }}</a>
          {% else %}
            <a href="{{ collection.url }}/{{ tag | handle }}" class="mc-filter-btn">{{ tag }}</a>
          {% endif %}
        {% endfor %}
      </div>

      <div class="mc-toolbar-right">
        <span class="mc-count">{{ collection.products_count }} products</span>
        <select class="mc-sort-select" onchange="window.location.href=this.value">
          <option value="{{ collection.url }}?sort_by=manual" {% if collection.sort_by == 'manual' %}selected{% endif %}>Featured</option>
          <option value="{{ collection.url }}?sort_by=best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
          <option value="{{ collection.url }}?sort_by=title-ascending" {% if collection.sort_by == 'title-ascending' %}selected{% endif %}>A-Z</option>
          <option value="{{ collection.url }}?sort_by=title-descending" {% if collection.sort_by == 'title-descending' %}selected{% endif %}>Z-A</option>
          <option value="{{ collection.url }}?sort_by=price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
          <option value="{{ collection.url }}?sort_by=price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
          <option value="{{ collection.url }}?sort_by=created-ascending" {% if collection.sort_by == 'created-ascending' %}selected{% endif %}>Oldest</option>
          <option value="{{ collection.url }}?sort_by=created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
        </select>
      </div>
    </div>

    <!-- Product Grid -->
    {% paginate collection.products by products_per_page %}
      <div class="mc-grid">
        {% for product in collection.products %}
          <a href="{{ product.url }}" class="mc-card">
            <div class="mc-card-img-wrap">
              {% if product.featured_image != blank %}
                <img
                  src="{{ product.featured_image | image_url: width: 480 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="480"
                  height="480"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
              {% if product.compare_at_price > product.price %}
                {%- assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                <span class="mc-card-badge">-{{ discount }}%</span>
              {% endif %}
            </div>
            <div class="mc-card-body">
              <h3 class="mc-card-title">{{ product.title }}</h3>
              <div class="mc-card-price">
                <span class="mc-card-price-current">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="mc-card-price-compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>
          </a>
        {% endfor %}

        <!-- Pagination -->
        {% if paginate.pages > 1 %}
          <div class="mc-pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" aria-label="Previous">&laquo;</a>
            {% endif %}
            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {% else %}
                <span class="mc-page-current">{{ part.title }}</span>
              {% endif %}
            {% endfor %}
            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" aria-label="Next">&raquo;</a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Collection Page",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per Page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ],
  "templates": ["collection"]
}
{% endschema %}
