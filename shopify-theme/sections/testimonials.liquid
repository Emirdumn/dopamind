<style>
  .testimonials-section {
    background: #E0E7D7;
    padding: 80px 0;
  }
  .testimonials-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .testimonials-title {
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #2d3a2a;
    margin-bottom: 48px;
  }
  .testimonials-carousel-wrap {
    position: relative;
  }
  .testimonials-carousel {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 8px;
  }
  .testimonials-carousel::-webkit-scrollbar {
    display: none;
  }
  .testimonial-card {
    flex: 0 0 340px;
    scroll-snap-align: start;
    background: #fff;
    border-radius: 16px;
    padding: 28px;
    box-shadow: 0 2px 16px rgba(45, 58, 42, 0.06);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  @media (max-width: 600px) {
    .testimonial-card {
      flex: 0 0 280px;
      padding: 20px;
    }
  }
  .testimonial-stars {
    color: #e8b931;
    font-size: 1rem;
    letter-spacing: 2px;
  }
  .testimonial-quote {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #2d3a2a;
    opacity: 0.85;
    flex: 1;
    font-style: italic;
  }
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .testimonial-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #B7C396;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    color: #2d3a2a;
    flex-shrink: 0;
  }
  .testimonial-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: #2d3a2a;
  }
  .testimonial-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: #fff;
    border: 1px solid rgba(45, 58, 42, 0.15);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 10px rgba(45, 58, 42, 0.1);
    transition: all 0.2s;
    z-index: 5;
    color: #2d3a2a;
    font-size: 1.2rem;
  }
  .testimonial-nav:hover {
    background: #5a7a52;
    color: #fff;
    border-color: #5a7a52;
  }
  .testimonial-nav--prev {
    left: -16px;
  }
  .testimonial-nav--next {
    right: -16px;
  }
  @media (max-width: 768px) {
    .testimonial-nav {
      display: none;
    }
  }
</style>

<section class="testimonials-section" data-section-id="{{ section.id }}">
  <div class="testimonials-inner">
    <h2 class="testimonials-title">{{ section.settings.heading }}</h2>

    <div class="testimonials-carousel-wrap">
      <button class="testimonial-nav testimonial-nav--prev" aria-label="Previous" onclick="(function(btn){ var c=btn.closest('.testimonials-carousel-wrap').querySelector('.testimonials-carousel'); c.scrollBy({left:-364, behavior:'smooth'}); })(this)">&#8592;</button>

      <div class="testimonials-carousel" id="testimonials-carousel-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            <div class="testimonial-stars">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.rating -%}&#9733;{%- else -%}&#9734;{%- endif -%}
              {%- endfor -%}
            </div>
            <p class="testimonial-quote">"{{ block.settings.quote }}"</p>
            <div class="testimonial-author">
              <div class="testimonial-avatar">
                {{ block.settings.author | truncate: 1, '' | upcase }}
              </div>
              <span class="testimonial-name">{{ block.settings.author }}</span>
            </div>
          </div>
        {% endfor %}
      </div>

      <button class="testimonial-nav testimonial-nav--next" aria-label="Next" onclick="(function(btn){ var c=btn.closest('.testimonials-carousel-wrap').querySelector('.testimonials-carousel'); c.scrollBy({left:364, behavior:'smooth'}); })(this)">&#8594;</button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This product has been a game-changer for my daily focus."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Sarah K."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "The fidget cube keeps my hands busy during meetings. I can finally concentrate on what's being said without zoning out!",
            "author": "Sarah K."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "As someone with ADHD, the visual timer has completely transformed how I manage my work blocks. No more time blindness!",
            "author": "Marcus T."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 4,
            "quote": "The ADHD planner is designed by someone who actually understands our brains. The layout makes so much sense.",
            "author": "Emily R."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "I bought the focus bundle for my son and the difference in his homework routine is incredible. Highly recommend!",
            "author": "David L."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Finally, products that don't treat ADHD as a problem to fix, but a brain to support. Love this brand's approach.",
            "author": "Aylin M."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 4,
            "quote": "The sensory tools help me self-regulate during stressful days. The quality is excellent and shipping was fast.",
            "author": "James W."
          }
        }
      ]
    }
  ]
}
{% endschema %}
