<style>
  .hero-section {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #E0E7D7;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(224, 231, 215, 0.92) 0%,
      rgba(183, 195, 150, 0.85) 50%,
      rgba(90, 122, 82, 0.78) 100%
    );
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding: 40px 24px;
  }
  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #2d3a2a;
    line-height: 1.2;
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }
  .hero-title br {
    display: block;
  }
  .hero-search {
    display: flex;
    max-width: 520px;
    margin: 0 auto 24px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(45, 58, 42, 0.12);
  }
  .hero-search input {
    flex: 1;
    padding: 16px 20px;
    border: none;
    outline: none;
    font-size: 1rem;
    background: #fff;
    color: #2d3a2a;
  }
  .hero-search input::placeholder {
    color: #2d3a2a;
    opacity: 0.5;
  }
  .hero-search button {
    padding: 16px 28px;
    background: #5a7a52;
    color: #fff;
    border: none;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .hero-search button:hover {
    background: #4a6a44;
  }
  .hero-cta {
    display: inline-block;
    margin-top: 16px;
    padding: 16px 40px;
    background: #5a7a52;
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 16px rgba(90, 122, 82, 0.3);
  }
  .hero-cta:hover {
    background: #4a6a44;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(90, 122, 82, 0.4);
  }
  @media (max-width: 600px) {
    .hero-search {
      flex-direction: column;
      border-radius: 12px;
    }
    .hero-search input {
      border-radius: 12px 12px 0 0;
    }
    .hero-search button {
      border-radius: 0 0 12px 12px;
    }
  }
</style>

<section class="hero-section" data-section-id="{{ section.id }}">
  {% if section.settings.background_image != blank %}
    <div class="hero-bg" style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');"></div>
  {% endif %}
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <h1 class="hero-title">
      {{ section.settings.heading_line1 }}<br>
      {{ section.settings.heading_line2 }}
    </h1>

    <form action="/search" method="get" class="hero-search">
      <input type="text" name="q" placeholder="{{ section.settings.search_placeholder }}" aria-label="Search products">
      <button type="submit">{{ section.settings.search_button_text }}</button>
    </form>

    <a href="{{ section.settings.cta_link }}" class="hero-cta">
      {{ section.settings.cta_text }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading Line 1",
      "default": "Your Brain Works Different."
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading Line 2",
      "default": "Your Tools Should Too."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder",
      "default": "Search products..."
    },
    {
      "type": "text",
      "id": "search_button_text",
      "label": "Search Button Text",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Start ADHD Test"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link",
      "default": "/pages/adhd-test"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
