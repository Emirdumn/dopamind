<style>
  .main-cart-section {
    background: #E0E7D7;
    padding: 60px 0 80px;
    min-height: 60vh;
  }
  .main-cart-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .main-cart-title {
    font-size: clamp(1.6rem, 3vw, 2rem);
    font-weight: 800;
    color: #2d3a2a;
    margin-bottom: 40px;
  }

  /* Empty state */
  .cart-empty {
    text-align: center;
    padding: 80px 20px;
  }
  .cart-empty-icon {
    margin-bottom: 24px;
  }
  .cart-empty-icon svg {
    width: 64px;
    height: 64px;
    stroke: #B7C396;
    fill: none;
    stroke-width: 1.5;
  }
  .cart-empty-text {
    font-size: 1.1rem;
    color: #2d3a2a;
    opacity: 0.7;
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .cart-empty-btn {
    display: inline-block;
    padding: 16px 40px;
    background: #5a7a52;
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 600;
    transition: background 0.2s;
  }
  .cart-empty-btn:hover {
    background: #4a6a44;
  }

  /* Cart header */
  .cart-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 40px;
    gap: 16px;
    padding-bottom: 16px;
    border-bottom: 2px solid rgba(45, 58, 42, 0.12);
    font-size: 0.8rem;
    font-weight: 600;
    color: #2d3a2a;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Cart item */
  .cart-item {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 40px;
    gap: 16px;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid rgba(45, 58, 42, 0.08);
  }
  .cart-item-product {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .cart-item-img {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 10px;
    background: #f0f4eb;
    flex-shrink: 0;
  }
  .cart-item-name {
    font-size: 0.95rem;
    color: #2d3a2a;
    text-decoration: none;
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
    transition: color 0.2s;
  }
  .cart-item-name:hover {
    color: #5a7a52;
  }
  .cart-item-variant {
    font-size: 0.8rem;
    color: #2d3a2a;
    opacity: 0.6;
    margin: 0;
  }
  .cart-item-price,
  .cart-item-total {
    font-size: 0.95rem;
    color: #2d3a2a;
    font-weight: 600;
  }

  /* Quantity controls */
  .cart-qty-controls {
    display: flex;
    align-items: center;
    border: 1.5px solid rgba(45, 58, 42, 0.2);
    border-radius: 8px;
    overflow: hidden;
    width: fit-content;
    background: #fff;
  }
  .cart-qty-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f4eb;
    color: #2d3a2a;
    text-decoration: none;
    font-size: 1.1rem;
    transition: background 0.2s;
  }
  .cart-qty-btn:hover {
    background: #dde4d5;
  }
  .cart-qty-input {
    width: 44px;
    text-align: center;
    border: none;
    font-size: 0.95rem;
    font-weight: 600;
    color: #2d3a2a;
    background: #fff;
    -moz-appearance: textfield;
  }
  .cart-qty-input::-webkit-outer-spin-button,
  .cart-qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }
  .cart-item-remove {
    color: #999;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-item-remove:hover {
    color: #d94f4f;
  }

  /* Summary */
  .cart-summary {
    max-width: 400px;
    margin-left: auto;
    margin-top: 32px;
    padding: 32px;
    background: rgba(255, 255, 255, 0.5);
    border-radius: 16px;
  }
  .cart-summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
    color: #2d3a2a;
    margin-bottom: 12px;
  }
  .cart-summary-row--total {
    font-size: 1.2rem;
    font-weight: 700;
    padding-top: 16px;
    border-top: 2px solid rgba(45, 58, 42, 0.12);
    margin-bottom: 24px;
  }
  .cart-summary-free {
    color: #5a7a52;
    font-weight: 600;
  }
  .cart-checkout-btn {
    width: 100%;
    padding: 18px;
    background: #5a7a52;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
    margin-bottom: 12px;
  }
  .cart-checkout-btn:hover {
    background: #4a6a44;
  }
  .cart-continue {
    display: block;
    text-align: center;
    color: #5a7a52;
    font-size: 0.9rem;
    text-decoration: none;
    font-weight: 600;
  }
  .cart-continue:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .cart-header { display: none; }
    .cart-item {
      grid-template-columns: 1fr;
      gap: 12px;
      position: relative;
      padding-right: 40px;
    }
    .cart-item-remove {
      position: absolute;
      top: 24px;
      right: 0;
    }
    .cart-summary {
      max-width: 100%;
    }
  }
</style>

<section class="main-cart-section" data-section-id="{{ section.id }}">
  <div class="main-cart-inner">
    <h1 class="main-cart-title">Your Cart</h1>

    {% if cart.item_count == 0 %}
      <div class="cart-empty">
        <div class="cart-empty-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <circle cx="9" cy="21" r="1"/>
            <circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
          </svg>
        </div>
        <p class="cart-empty-text">{{ section.settings.empty_text }}</p>
        <a href="/collections/all" class="cart-empty-btn">Continue Shopping</a>
      </div>
    {% else %}
      <form action="/cart" method="post">
        <div class="cart-header">
          <span>Product</span>
          <span>Price</span>
          <span>Quantity</span>
          <span>Total</span>
          <span></span>
        </div>

        {% for item in cart.items %}
          <div class="cart-item">
            <div class="cart-item-product">
              <a href="{{ item.url }}">
                {% if item.image %}
                  <img
                    src="{{ item.image | image_url: width: 160 }}"
                    alt="{{ item.title | escape }}"
                    class="cart-item-img"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                {% endif %}
              </a>
              <div>
                <a href="{{ item.url }}" class="cart-item-name">{{ item.product.title }}</a>
                {% if item.variant.title != 'Default Title' %}
                  <p class="cart-item-variant">{{ item.variant.title }}</p>
                {% endif %}
              </div>
            </div>

            <div class="cart-item-price">{{ item.price | money }}</div>

            <div>
              <div class="cart-qty-controls">
                <a href="/cart/change?id={{ item.key }}&quantity={{ item.quantity | minus: 1 }}" class="cart-qty-btn" aria-label="Decrease quantity">-</a>
                <input
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  class="cart-qty-input"
                  aria-label="Quantity for {{ item.product.title }}"
                >
                <a href="/cart/change?id={{ item.key }}&quantity={{ item.quantity | plus: 1 }}" class="cart-qty-btn" aria-label="Increase quantity">+</a>
              </div>
            </div>

            <div class="cart-item-total">{{ item.line_price | money }}</div>

            <a href="/cart/change?id={{ item.key }}&quantity=0" class="cart-item-remove" aria-label="Remove {{ item.product.title }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 6L6 18M6 6l12 12"/>
              </svg>
            </a>
          </div>
        {% endfor %}

        <div class="cart-summary">
          <div class="cart-summary-row">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <div class="cart-summary-row">
            <span>Shipping</span>
            <span class="cart-summary-free">Free</span>
          </div>
          <div class="cart-summary-row cart-summary-row--total">
            <span>Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <button type="submit" name="checkout" class="cart-checkout-btn">
            Proceed to Checkout
          </button>
          <a href="/collections/all" class="cart-continue">Continue Shopping</a>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart Page",
  "settings": [
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty Cart Text",
      "default": "Your cart is empty. Discover products designed for the ADHD brain!"
    }
  ],
  "templates": ["cart"]
}
{% endschema %}
