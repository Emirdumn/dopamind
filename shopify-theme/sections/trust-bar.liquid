<style>
  .trust-bar-section {
    background: #E0E7D7;
    padding: 32px 0;
    border-bottom: 1px solid rgba(45, 58, 42, 0.08);
  }
  .trust-bar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .trust-bar-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .trust-bar-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 10px;
    transition: background 0.2s;
  }
  .trust-bar-item:hover {
    background: rgba(255, 255, 255, 0.6);
  }
  .trust-bar-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }
  .trust-bar-text {
    font-size: 0.9rem;
    font-weight: 600;
    color: #2d3a2a;
    line-height: 1.3;
  }
  @media (max-width: 768px) {
    .trust-bar-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }
  @media (max-width: 480px) {
    .trust-bar-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="trust-bar-section" data-section-id="{{ section.id }}">
  <div class="trust-bar-inner">
    <div class="trust-bar-grid">
      {% for block in section.blocks %}
        <div class="trust-bar-item" {{ block.shopify_attributes }}>
          <span class="trust-bar-icon">{{ block.settings.icon }}</span>
          <span class="trust-bar-text">{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "\ud83d\ude9a"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "\ud83d\ude9a", "text": "Free Shipping" } },
        { "type": "trust_item", "settings": { "icon": "\ud83d\udd04", "text": "30-Day Returns" } },
        { "type": "trust_item", "settings": { "icon": "\ud83d\udd12", "text": "Secure Payment" } },
        { "type": "trust_item", "settings": { "icon": "\ud83e\udde0", "text": "ADHD Expert Approved" } }
      ]
    }
  ]
}
{% endschema %}
