<style>
  .categories-section {
    background: #E0E7D7;
    padding: 80px 0;
  }
  .categories-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .categories-title {
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    font-style: italic;
    font-family: Georgia, 'Times New Roman', serif;
    color: #2d3a2a;
    margin-bottom: 48px;
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .category-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 4px 20px rgba(45, 58, 42, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: #2d3a2a;
    display: block;
  }
  .category-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 36px rgba(45, 58, 42, 0.15);
  }
  .category-card-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    background: #B7C396;
  }
  .category-card-img-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, #B7C396 0%, #5a7a52 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
  }
  .category-card-body {
    padding: 20px 24px 24px;
  }
  .category-card-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #2d3a2a;
  }
  .category-card-desc {
    font-size: 0.9rem;
    color: #2d3a2a;
    opacity: 0.7;
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .categories-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>

<section class="categories-section" data-section-id="{{ section.id }}">
  <div class="categories-inner">
    <h2 class="categories-title">{{ section.settings.heading }}</h2>

    <div class="categories-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="category-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img
              class="category-card-img"
              src="{{ block.settings.image | image_url: width: 600 }}"
              alt="{{ block.settings.title }}"
              loading="lazy"
              width="600"
              height="450"
            >
          {% else %}
            <div class="category-card-img-placeholder">
              {{ block.settings.icon }}
            </div>
          {% endif %}
          <div class="category-card-body">
            <h3 class="category-card-title">{{ block.settings.title }}</h3>
            <p class="category-card-desc">{{ block.settings.description }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Categories of The Month"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Fallback Icon (emoji)",
          "default": "\ud83c\udfb2"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fidget Cube"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Tactile tools to help maintain focus and reduce anxiety."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "default": "/collections/all"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "icon": "\ud83c\udfb2",
            "title": "Fidget Cube",
            "description": "Tactile tools to help maintain focus and reduce anxiety.",
            "link": "/collections/fidget-cube"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "\u23f1\ufe0f",
            "title": "Timer",
            "description": "Visual timers designed for time blindness and task management.",
            "link": "/collections/timer"
          }
        },
        {
          "type": "category",
          "settings": {
            "icon": "\ud83d\udcd3",
            "title": "Planner",
            "description": "ADHD-friendly planners built for neurodivergent minds.",
            "link": "/collections/planner"
          }
        }
      ]
    }
  ]
}
{% endschema %}
