<style>
  .header-section {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(224, 231, 215, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(45, 58, 42, 0.1);
    transition: box-shadow 0.3s ease;
  }
  .header-section.scrolled {
    box-shadow: 0 2px 20px rgba(45, 58, 42, 0.1);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
  }
  .header-left,
  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 1;
  }
  .header-right {
    justify-content: flex-end;
  }
  .header-center {
    flex: 0 0 auto;
  }
  .header-logo {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #2d3a2a;
    text-decoration: none;
    white-space: nowrap;
  }
  .hamburger-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: center;
    justify-content: center;
  }
  .hamburger-btn span {
    display: block;
    width: 22px;
    height: 2px;
    background: #2d3a2a;
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  .header-icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    position: relative;
    color: #2d3a2a;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .header-icon-btn svg {
    width: 22px;
    height: 22px;
    stroke: #2d3a2a;
    fill: none;
    stroke-width: 1.8;
  }
  .cart-count {
    position: absolute;
    top: 2px;
    right: 0;
    background: #5a7a52;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* Mobile slide-in menu */
  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    background: rgba(45, 58, 42, 0.4);
    z-index: 2000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }
  .mobile-menu-overlay.active {
    opacity: 1;
    visibility: visible;
  }
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 320px;
    max-width: 85vw;
    background: #b8d4b8;
    z-index: 2001;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  .mobile-menu.active {
    transform: translateX(0);
  }
  .mobile-menu-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(45, 58, 42, 0.15);
  }
  .mobile-menu-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: #2d3a2a;
    font-size: 24px;
    line-height: 1;
  }
  .mobile-nav {
    padding: 24px;
    flex: 1;
  }
  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 0;
    text-decoration: none;
    color: #2d3a2a;
    font-size: 1.05rem;
    font-weight: 500;
    border-bottom: 1px solid rgba(45, 58, 42, 0.1);
    transition: color 0.2s;
  }
  .mobile-nav-link:hover {
    color: #5a7a52;
  }
  .mobile-nav-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: #5a7a52;
    min-width: 24px;
  }
  .mobile-menu-footer {
    padding: 24px;
    border-top: 1px solid rgba(45, 58, 42, 0.15);
  }
  .lang-selector {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 20px;
  }
  .lang-flag {
    font-size: 1.4rem;
    cursor: pointer;
    transition: transform 0.2s;
    text-decoration: none;
  }
  .lang-flag:hover {
    transform: scale(1.2);
  }
  .mobile-auth-links {
    display: flex;
    gap: 16px;
  }
  .mobile-auth-links a {
    color: #2d3a2a;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 8px 16px;
    border: 1.5px solid #2d3a2a;
    border-radius: 6px;
    transition: all 0.2s;
  }
  .mobile-auth-links a:hover {
    background: #2d3a2a;
    color: #E0E7D7;
  }
</style>

<header class="header-section" data-section-id="{{ section.id }}">
  <div class="header-inner">
    <div class="header-left">
      <button class="hamburger-btn" aria-label="Open menu" onclick="document.getElementById('mobile-menu-{{ section.id }}').classList.add('active'); document.getElementById('mobile-overlay-{{ section.id }}').classList.add('active'); document.body.style.overflow='hidden';">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <div class="header-center">
      <a href="/" class="header-logo">{{ section.settings.logo_text }}</a>
    </div>

    <div class="header-right">
      <a href="/cart" class="header-icon-btn" aria-label="Cart">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="3" y1="6" x2="21" y2="6" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M16 10a4 4 0 01-8 0" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>
      <a href="/account" class="header-icon-btn" aria-label="Account">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="12" cy="7" r="4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu-overlay" id="mobile-overlay-{{ section.id }}" onclick="document.getElementById('mobile-menu-{{ section.id }}').classList.remove('active'); this.classList.remove('active'); document.body.style.overflow='';"></div>

<!-- Mobile Slide-in Menu -->
<nav class="mobile-menu" id="mobile-menu-{{ section.id }}">
  <div class="mobile-menu-header">
    <a href="/" class="header-logo">{{ section.settings.logo_text }}</a>
    <button class="mobile-menu-close" aria-label="Close menu" onclick="this.closest('.mobile-menu').classList.remove('active'); document.getElementById('mobile-overlay-{{ section.id }}').classList.remove('active'); document.body.style.overflow='';">
      &times;
    </button>
  </div>

  <div class="mobile-nav">
    {% for block in section.blocks %}
      {% if block.type == 'menu_link' %}
        <a href="{{ block.settings.link }}" class="mobile-nav-link" {{ block.shopify_attributes }}>
          <span class="mobile-nav-num">{{ block.settings.number }}</span>
          <span>{{ block.settings.label }}</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>

  <div class="mobile-menu-footer">
    <div class="lang-selector">
      <a href="?lang=tr" class="lang-flag" title="Turkce">🇹🇷</a>
      <a href="?lang=en" class="lang-flag" title="English">🇬🇧</a>
      <a href="?lang=es" class="lang-flag" title="Espanol">🇪🇸</a>
      <a href="?lang=ru" class="lang-flag" title="Russian">🇷🇺</a>
      <a href="?lang=ar" class="lang-flag" title="Arabic">🇸🇦</a>
      <a href="?lang=zh" class="lang-flag" title="Chinese">🇨🇳</a>
      <a href="?lang=id" class="lang-flag" title="Indonesian">🇮🇩</a>
    </div>
    <div class="mobile-auth-links">
      <a href="/account/login">Login</a>
      <a href="/account/register">Register</a>
    </div>
  </div>
</nav>

<!-- Spacer for fixed header -->
<div style="height: 64px;"></div>

<script>
  (function() {
    var header = document.querySelector('.header-section');
    window.addEventListener('scroll', function() {
      if (window.scrollY > 10) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "class": "header-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "DOPAMİND"
    }
  ],
  "blocks": [
    {
      "type": "menu_link",
      "name": "Menu Link",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Home"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "default": "/"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "menu_link", "settings": { "number": "01", "label": "Home", "link": "/" } },
        { "type": "menu_link", "settings": { "number": "02", "label": "Products", "link": "/collections/all" } },
        { "type": "menu_link", "settings": { "number": "03", "label": "About", "link": "/pages/about" } },
        { "type": "menu_link", "settings": { "number": "04", "label": "Blog", "link": "/blogs/news" } },
        { "type": "menu_link", "settings": { "number": "05", "label": "ADHD Test", "link": "/pages/adhd-test" } }
      ]
    }
  ]
}
{% endschema %}
