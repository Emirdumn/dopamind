<style>
  .main-page-section {
    background: #E0E7D7;
    padding: 60px 0 80px;
    min-height: 50vh;
  }
  .main-page-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .main-page-title {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 800;
    color: #2d3a2a;
    margin-bottom: 32px;
    text-align: center;
  }
  .main-page-content {
    font-size: 1rem;
    color: #2d3a2a;
    line-height: 1.8;
  }
  .main-page-content h2 {
    font-size: 1.6rem;
    color: #2d3a2a;
    margin-top: 40px;
    margin-bottom: 16px;
    font-weight: 700;
  }
  .main-page-content h3 {
    font-size: 1.3rem;
    color: #2d3a2a;
    margin-top: 32px;
    margin-bottom: 12px;
    font-weight: 600;
  }
  .main-page-content p {
    margin-bottom: 16px;
  }
  .main-page-content a {
    color: #5a7a52;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .main-page-content a:hover {
    color: #4a6a44;
  }
  .main-page-content ul,
  .main-page-content ol {
    margin-bottom: 16px;
    padding-left: 24px;
  }
  .main-page-content li {
    margin-bottom: 8px;
  }
  .main-page-content img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 24px 0;
  }
  .main-page-content blockquote {
    border-left: 4px solid #B7C396;
    padding: 16px 24px;
    margin: 24px 0;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 0 10px 10px 0;
    font-style: italic;
    color: #2d3a2a;
    opacity: 0.85;
  }
  .main-page-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
  }
  .main-page-content th,
  .main-page-content td {
    padding: 12px 16px;
    border: 1px solid rgba(45, 58, 42, 0.12);
    text-align: left;
  }
  .main-page-content th {
    background: rgba(90, 122, 82, 0.1);
    font-weight: 600;
  }
  @media (max-width: 768px) {
    .main-page-content {
      font-size: 0.95rem;
    }
  }
</style>

<section class="main-page-section" data-section-id="{{ section.id }}">
  <div class="main-page-inner">
    {% if section.settings.show_title %}
      <h1 class="main-page-title">{{ page.title }}</h1>
    {% endif %}
    <div class="main-page-content rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Page Title",
      "default": true
    }
  ],
  "templates": ["page"]
}
{% endschema %}
