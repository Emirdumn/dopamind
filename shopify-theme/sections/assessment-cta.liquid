<style>
  .assessment-cta-section {
    background: #5a7a52;
    padding: 80px 0;
  }
  .assessment-cta-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
  }
  .assessment-cta-heading {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 20px;
    line-height: 1.2;
  }
  .assessment-cta-desc {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  .assessment-cta-btn {
    display: inline-block;
    padding: 18px 48px;
    background: #fff;
    color: #5a7a52;
    text-decoration: none;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 700;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }
  .assessment-cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    background: #f5f7f0;
  }
</style>

<section class="assessment-cta-section" data-section-id="{{ section.id }}">
  <div class="assessment-cta-inner">
    <h2 class="assessment-cta-heading">{{ section.settings.heading }}</h2>
    <p class="assessment-cta-desc">{{ section.settings.description }}</p>
    <a href="{{ section.settings.button_link }}" class="assessment-cta-btn">
      {{ section.settings.button_text }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Assessment CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover Your ADHD Profile"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Take our free assessment to understand your unique ADHD traits and get personalized product recommendations tailored to your needs."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Start Free Assessment"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/pages/adhd-test"
    }
  ],
  "presets": [
    {
      "name": "Assessment CTA"
    }
  ]
}
{% endschema %}
