<style>
  .featured-products-section {
    background: #E0E7D7;
    padding: 80px 0;
  }
  .featured-products-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .featured-products-title {
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #2d3a2a;
    margin-bottom: 48px;
  }
  .featured-products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  @media (max-width: 1024px) {
    .featured-products-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .featured-products-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }
  @media (max-width: 480px) {
    .featured-products-grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin-left: auto;
      margin-right: auto;
    }
  }
  .fp-card {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(45, 58, 42, 0.06);
    transition: transform 0.3s, box-shadow 0.3s;
    text-decoration: none;
    color: #2d3a2a;
    display: flex;
    flex-direction: column;
  }
  .fp-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(45, 58, 42, 0.12);
  }
  .fp-card-img-wrap {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #f0f4eb;
  }
  .fp-card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .fp-card:hover .fp-card-img-wrap img {
    transform: scale(1.05);
  }
  .fp-card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #5a7a52;
    color: #fff;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
  }
  .fp-card-body {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .fp-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 8px;
    line-height: 1.3;
    color: #2d3a2a;
  }
  .fp-card-price {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .fp-card-price-current {
    font-size: 1.05rem;
    font-weight: 700;
    color: #5a7a52;
  }
  .fp-card-price-compare {
    font-size: 0.85rem;
    color: #2d3a2a;
    opacity: 0.5;
    text-decoration: line-through;
  }
  .featured-products-viewall {
    text-align: center;
    margin-top: 40px;
  }
  .featured-products-viewall a {
    display: inline-block;
    padding: 14px 36px;
    border: 2px solid #5a7a52;
    color: #5a7a52;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s;
  }
  .featured-products-viewall a:hover {
    background: #5a7a52;
    color: #fff;
  }
</style>

<section class="featured-products-section" data-section-id="{{ section.id }}">
  <div class="featured-products-inner">
    <h2 class="featured-products-title">{{ section.settings.heading }}</h2>

    {%- assign featured_collection = section.settings.collection -%}
    {%- assign products_to_show = section.settings.products_to_show -%}

    <div class="featured-products-grid">
      {% if featured_collection != blank %}
        {% for product in collections[featured_collection].products limit: products_to_show %}
          <a href="{{ product.url }}" class="fp-card">
            <div class="fp-card-img-wrap">
              {% if product.featured_image != blank %}
                <img
                  src="{{ product.featured_image | image_url: width: 480 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="480"
                  height="480"
                >
              {% endif %}
              {% if product.compare_at_price > product.price %}
                {%- assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                <span class="fp-card-badge">-{{ discount }}%</span>
              {% endif %}
            </div>
            <div class="fp-card-body">
              <h3 class="fp-card-title">{{ product.title }}</h3>
              <div class="fp-card-price">
                <span class="fp-card-price-current">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="fp-card-price-compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% for i in (1..products_to_show) %}
          <div class="fp-card">
            <div class="fp-card-img-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="fp-card-body">
              <h3 class="fp-card-title">Sample Product {{ i }}</h3>
              <div class="fp-card-price">
                <span class="fp-card-price-current">$29.99</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="featured-products-viewall">
      <a href="{% if featured_collection != blank %}/collections/{{ featured_collection }}{% else %}/collections/all{% endif %}">
        {{ section.settings.viewall_text }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to Show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "viewall_text",
      "label": "View All Button Text",
      "default": "View All"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
