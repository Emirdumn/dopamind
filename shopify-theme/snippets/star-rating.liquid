{% comment %}
  Star Rating Snippet
  Accepts: rating (number 0-5)
  Usage: {% render 'star-rating', rating: product.metafields.reviews.rating.value %}
{% endcomment %}

{%- liquid
  assign rating_value = rating | default: 0 | times: 1.0
  assign full_stars = rating_value | floor
  assign half_check = rating_value | minus: full_stars
  assign empty_stars = 5 | minus: full_stars
  if half_check > 0
    assign empty_stars = empty_stars | minus: 1
  endif
-%}

<span class="star-rating" aria-label="{{ rating_value }} / 5">
  <span class="star-rating__stars">
    {%- for i in (1..full_stars) -%}
      <span class="star-rating__star star-rating__star--filled" aria-hidden="true">&#9733;</span>
    {%- endfor -%}

    {%- if half_check > 0 -%}
      <span class="star-rating__star star-rating__star--half" aria-hidden="true">&#9733;</span>
    {%- endif -%}

    {%- for i in (1..empty_stars) -%}
      <span class="star-rating__star star-rating__star--empty" aria-hidden="true">&#9734;</span>
    {%- endfor -%}
  </span>
  <span class="star-rating__value">{{ rating_value }}</span>
</span>

<style>
  .star-rating {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .star-rating__stars {
    display: inline-flex;
    gap: 1px;
    font-size: 14px;
    line-height: 1;
  }

  .star-rating__star--filled {
    color: #f4b740;
  }

  .star-rating__star--half {
    color: #f4b740;
    position: relative;
    opacity: 0.6;
  }

  .star-rating__star--empty {
    color: #d0d5ce;
  }

  .star-rating__value {
    font-size: 13px;
    font-weight: 600;
    color: #6b7c68;
  }
</style>
